{
  "name": "rotary-minutes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "node scripts/setup-local-env.mjs && docker compose up -d && npx prisma db push && npm run db:seed && next dev",
    "build": "next build",
    "start": "next start",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "verify": "npx tsx scripts/verify-app.mjs",
    "verify:integrations": "npx tsx scripts/verify-integrations.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons:generate": "node scripts/generate-branding-assets.mjs",
    "branding:generate": "node scripts/generate-branding-assets.mjs",
    "android:init": "npm run icons:generate && npx cap add android",
    "android:sync": "npm run icons:generate && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "android:build": "node scripts/android-build.mjs",
    "android:apk": "node scripts/build-android-apk.mjs",
    "android:sdk": "powershell -ExecutionPolicy Bypass -File scripts/setup-android-sdk.ps1",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^5.4.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query": "^5.101.2",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "idb": "^8.0.3",
    "isomorphic-dompurify": "^3.18.0",
    "lucide-react": "^1.23.0",
    "marked": "^18.0.5",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.1",
    "nodemailer": "^7.0.7",
    "pg": "^8.22.0",
    "pg-cloudflare": "^1.4.0",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "resend": "^6.17.1",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "uuid": "^14.0.1",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@capacitor/cli": "^7.2.0",
    "eslint": "^9",
    "sharp": "^0.34.2",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^3.2.7",
    "wrangler": "^4.107.0"
  }
}
