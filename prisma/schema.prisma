generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Language {
  FR
  EN
}

enum ClubType {
  ROTARY
  ROTARACT
}

enum ClubRole {
  PRESIDENT
  SECRETARY
  PROTOCOL
  TREASURER
  FOUNDATION_CHAIR
  MEMBERSHIP_CHAIR
  PUBLIC_IMAGE_CHAIR
  ADMIN
  READER
}

enum MeetingType {
  STATUTORY
  COMMITTEE
  COMMISSION
  GENERAL_ASSEMBLY
  JOINT_MEETING
  GOVERNOR_VISIT
  TRAINING
  SPECIAL
}

enum AttendanceCategory {
  PRESENT
  EXCUSED_ABSENT
  UNEXCUSED_ABSENT
  TRAVELING
  TRAVEL_RETURN
  ROTARY_GUEST
  ROTARACT_GUEST
  NON_ROTARY_GUEST
  SPEAKER
  VISITOR
  BIRTHDAY
  EXTERNAL_ATTENDANCE
}

enum MinuteStatus {
  DRAFT
  IN_PROGRESS
  REVIEW
  FINALIZED
  ARCHIVED
}

enum AgendaItemStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  DEFERRED
  CANCELLED
}

enum SubscriptionPlan {
  TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum NotificationType {
  MEETING_REMINDER
  ACTION_REMINDER
  DEADLINE_REMINDER
  NEW_MEETING
  NEW_MINUTE
  SYSTEM
  ANNOUNCEMENT
  DUES_REMINDER
  BIRTHDAY_REMINDER
  EVENT_REMINDER
  GOVERNANCE_UPDATE
}

enum BudgetEntryType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  CHECK
  BANK_TRANSFER
  STRIPE
  MOBILE_MONEY
  OTHER
}

enum ClubActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DEFERRED
}

enum ClubActionPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ClubEventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventRegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  WAITLIST
}

enum TreasuryCollectionStatus {
  COLLECTED
  RECEIVABLE
}

enum BackupScope {
  FULL
  DATABASE_ONLY
}

enum BackupJobStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DocumentCategory {
  STATUTES
  BUDGET
  MANDATE
  MINUTE
  REPORT
  TREASURY
  OTHER
}

enum GovernanceRecordType {
  MANDATE_START
  MANDATE_END
  COLLAR_TRANSFER
  MINUTE_SUBMITTED
  MINUTE_APPROVED
  MINUTE_FINALIZED
  OFFICER_CHANGE
}

enum NotificationFrequency {
  IMMEDIATE
  DAILY
  WEEKLY
  OFF
}

enum CalendarEventSource {
  MEETING
  EVENT
  DUES
  ACTION
  BIRTHDAY
  CUSTOM
}

enum DuesStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
}

enum DuesPaymentPlan {
  MONTHLY
  ANNUAL
}

enum AnnouncementTarget {
  ALL_CLUBS
  CLUB
  USERS
  ROLE
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum PromoDiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum AddonKey {
  EMAILS
  DISTRICT
  ADVANCED_STATS
}

enum DistrictAccessRole {
  VIEWER
  GOVERNOR
  ADG
}

enum DataRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum CheckInMethod {
  QR
  MANUAL
}

enum OnboardingStepKey {
  CLUB_PROFILE
  MEMBERS
  FIRST_MEETING
  INVITE_USERS
  FIRST_MINUTE
  COMPLETE
}

enum ContactSubmissionStatus {
  NEW
  READ
  ARCHIVED
}

enum MembershipApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Auth (NextAuth) ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Multi-tenant Core ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  firstName     String
  lastName      String
  image         String?
  isSuperAdmin  Boolean   @default(false)
  language      Language  @default(FR)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   ClubMembership[]
  minutesAuthored Minute[] @relation("MinuteAuthor")
  minuteVersions  MinuteVersion[]
  notifications Notification[]
  auditLogs     AuditLog[]
  districtAccess  DistrictAccess[]
  districtAccessGranted DistrictAccess[] @relation("DistrictAccessGrantedBy")
  announcements Announcement[]
  minutesSubmitted Minute[] @relation("MinuteSubmitter")
  minutesApproved  Minute[] @relation("MinuteApprover")
  memberProfile    Member?
  duesPaymentsRecorded DuesPayment[]
  budgetEntriesRecorded BudgetEntry[]
  clubActionsCreated ClubAction[] @relation("ActionCreator")
  clubDocumentsUploaded ClubDocument[]
  clubBackupsCreated ClubBackup[] @relation("ClubBackupCreator")
  platformBackupsCreated PlatformBackup[] @relation("PlatformBackupCreator")
  governanceRecordsCreated GovernanceRecord[]
  notificationPreferences NotificationPreference[]
  supportTickets   SupportTicket[]
  dataExportRequests DataExportRequest[]
  pushSubscriptions PushSubscription[]
  clubAnnouncementsAuthored ClubAnnouncement[]
  deletionRequests   DeletionRequest[]
  consentRecords     ConsentRecord[]
}

model Club {
  id              String    @id @default(cuid())
  slug            String    @unique
  name            String
  type            ClubType  @default(ROTARY)
  logoUrl         String?
  district        String?
  country         String
  city            String
  address         String?
  meetingLocation String?
  meetingDay      String?
  meetingTime     String?
  email           String?
  phone           String?
  website         String?
  presidentName   String?
  secretaryName   String?
  memberCount     Int       @default(0)
  foundedAt       DateTime?
  currency              String    @default("EUR")
  defaultAnnualDues     Decimal?  @db.Decimal(10, 2)
  duesAutoInvoiceEmail  Boolean   @default(false)
  duesAutoReceiptEmail  Boolean   @default(true)
  description     String?   @db.Text
  timezone        String    @default("Europe/Paris")
  language        Language  @default(FR)
  isActive        Boolean   @default(true)
  presidentApprovalRequired Boolean @default(true)
  publicCalendarToken       String?  @unique
  whatsappReminderPhone     String?
  guideEnabled              Boolean  @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships     ClubMembership[]
  pushSubscriptions PushSubscription[]
  bankStatementLines BankStatementLine[]
  clubAnnouncements ClubAnnouncement[]
  members         Member[]
  commissions     Commission[]
  meetings        Meeting[]
  minutes         Minute[]
  emailContacts   EmailContact[]
  emailGroups     EmailGroup[]
  emailTemplates  EmailTemplate[]
  emailCampaigns  EmailCampaign[]
  notifications   Notification[]
  subscription    Subscription?
  auditLogs       AuditLog[]
  features        ClubFeatures?
  clubAddons      ClubAddon[]
  clubOnboarding  ClubOnboarding?
  referralsGiven  Referral[] @relation("ReferrerClub")
  officerMandates OfficerMandate[]
  supportTickets  SupportTicket[]
  featureFlagOverrides ClubFeatureFlagOverride[]
  apiKeys         ClubApiKey[]
  webhooks        ClubWebhook[]
  memberDues      MemberDues[]
  duesPayments    DuesPayment[]
  budgetCategories BudgetCategory[]
  budgetEntries   BudgetEntry[]
  clubActions     ClubAction[]
  clubEvents      ClubEvent[]
  clubDocuments   ClubDocument[]
  documentFolders DocumentFolder[]
  clubBackups     ClubBackup[]
  governanceRecords GovernanceRecord[]
  calendarNotes   ClubCalendarNote[]
  treasurySubAccounts TreasurySubAccount[]
  emailSettings   ClubEmailSettings?
  duesPaymentSettings ClubDuesPaymentSettings?
}

model ClubMembership {
  id             String                   @id @default(cuid())
  clubId         String
  userId         String
  role           ClubRole                 @default(READER)
  customRoleId   String?
  approvalStatus MembershipApprovalStatus @default(APPROVED)
  isActive       Boolean                  @default(true)
  joinedAt       DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  club       Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  customRole CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([userId])
  @@index([clubId, approvalStatus])
}

model Member {
  id           String    @id @default(cuid())
  clubId       String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  position     String?
  joinDate     DateTime?
  isActive     Boolean   @default(true)
  birthday     DateTime?
  photoUrl     String?
  bio          String?   @db.Text
  commissionId String?
  sponsorName  String?
  registrationNumber String?
  userId           String?          @unique
  duesPaymentPlan  DuesPaymentPlan  @default(ANNUAL)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  club         Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  commission   Commission? @relation(fields: [commissionId], references: [id], onDelete: SetNull)
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  attendances  MeetingAttendance[]
  officerMandates OfficerMandate[]
  memberDues   MemberDues[]
  duesPayments DuesPayment[]
  assignedActions ClubAction[] @relation("MemberAssignedActions")
  eventRegistrations EventRegistration[]

  @@index([clubId])
}

model MemberDues {
  id              String           @id @default(cuid())
  clubId          String
  memberId        String
  fiscalYear      Int
  periodIndex     Int              @default(0)
  periodLabel     String?
  paymentPlan     DuesPaymentPlan  @default(ANNUAL)
  amount          Decimal          @db.Decimal(10, 2)
  currency        String           @default("EUR")
  dueDate         DateTime
  paidAt          DateTime?
  status          DuesStatus       @default(PENDING)
  lastRemindedAt  DateTime?
  invoiceNumber   String?
  invoiceSentAt   DateTime?
  receiptNumber   String?
  receiptSentAt   DateTime?
  notes           String?

  club            Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member          Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  payments        DuesPayment[]

  @@unique([memberId, fiscalYear, periodIndex])
  @@index([clubId, fiscalYear])
  @@index([status, dueDate])
}

model DuesPayment {
  id            String   @id @default(cuid())
  clubId        String
  memberId      String
  duesId        String?
  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("EUR")
  paidAt        DateTime @default(now())
  method        String?
  paymentMethod PaymentMethod?
  reference     String?
  notes         String?
  receiptNumber String?
  receiptSentAt DateTime?
  recordedById  String?
  createdAt     DateTime @default(now())

  club       Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  member     Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  dues       MemberDues? @relation(fields: [duesId], references: [id], onDelete: SetNull)
  recordedBy User?       @relation(fields: [recordedById], references: [id], onDelete: SetNull)
  budgetEntries BudgetEntry[]

  @@index([clubId, memberId])
  @@index([duesId])
}

model Commission {
  id        String   @id @default(cuid())
  clubId    String
  name      String
  chairName String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members   Member[]

  @@index([clubId])
}

// ─── Meetings & Minutes ──────────────────────────────────────────────────────

model Meeting {
  id              String      @id @default(cuid())
  clubId          String
  title           String?
  date            DateTime
  location        String?
  startTime       String?
  endTime         String?
  presidedBy      String?
  secretary       String?
  type            MeetingType @default(STATUTORY)
  // Type-specific fields (JSON for flexibility)
  typeMetadata    Json?
  isLive          Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  club            Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  attendances     MeetingAttendance[]
  minute          Minute?
  checkInToken    MeetingCheckInToken?

  @@index([clubId, date])
}

model MeetingAttendance {
  id         String             @id @default(cuid())
  meetingId  String
  memberId   String?
  guestName  String?
  category   AttendanceCategory
  notes      String?

  meeting    Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  member     Member?            @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([meetingId])
}

model Minute {
  id              String       @id @default(cuid())
  clubId          String
  meetingId       String       @unique
  title           String
  status          MinuteStatus @default(DRAFT)
  contentHash     String?
  qrCodeUrl       String?
  verifyUrl       String?
  freeText        String?      @db.Text
  authorId        String?
  submittedAt     DateTime?
  submittedById   String?
  reviewComment   String?
  approvedAt      DateTime?
  approvedById    String?
  finalizedAt     DateTime?
  archivedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  club            Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  meeting         Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  author          User?        @relation("MinuteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  submittedBy     User?        @relation("MinuteSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  approvedBy      User?        @relation("MinuteApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  agendaItems     AgendaItem[]
  versions        MinuteVersion[]
  clubActions     ClubAction[]
  clubDocuments   ClubDocument[]
  governanceRecords GovernanceRecord[]

  @@index([clubId, status])
  @@index([clubId, createdAt])
  @@index([contentHash])
}

model AgendaItem {
  id           String           @id @default(cuid())
  minuteId     String
  sortOrder    Int              @default(0)
  title        String
  description  String?          @db.Text
  decisions    String?          @db.Text
  actions      String?          @db.Text
  responsible  String?
  dueDate      DateTime?
  status       AgendaItemStatus @default(OPEN)
  comments     String?          @db.Text
  remarks      String?          @db.Text

  minute       Minute           @relation(fields: [minuteId], references: [id], onDelete: Cascade)
  clubActions  ClubAction[]

  @@index([minuteId])
}

model MinuteVersion {
  id          String   @id @default(cuid())
  minuteId    String
  version     Int
  snapshot    Json
  contentHash String
  authorId    String?
  createdAt   DateTime @default(now())

  minute      Minute   @relation(fields: [minuteId], references: [id], onDelete: Cascade)
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@unique([minuteId, version])
  @@index([minuteId])
}

// ─── Email Module ────────────────────────────────────────────────────────────

model EmailContact {
  id        String   @id @default(cuid())
  clubId    String
  email     String
  firstName String?
  lastName  String?
  company   String?
  tags      String[]
  createdAt DateTime @default(now())

  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  groups    EmailGroupContact[]

  @@unique([clubId, email])
  @@index([clubId])
}

model EmailGroup {
  id          String   @id @default(cuid())
  clubId      String
  name        String
  description String?
  createdAt   DateTime @default(now())

  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  contacts    EmailGroupContact[]
  campaigns   EmailCampaign[]

  @@index([clubId])
}

model EmailGroupContact {
  id        String @id @default(cuid())
  groupId   String
  contactId String

  group     EmailGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contact   EmailContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([groupId, contactId])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  clubId    String?
  name      String
  slug      String
  subject   String
  body      String   @db.Text
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club      Club?    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  campaigns EmailCampaign[]

  @@index([clubId])
}

model EmailCampaign {
  id           String              @id @default(cuid())
  clubId       String
  templateId   String?
  groupId      String?
  name         String
  subject      String
  body         String              @db.Text
  recipients   String[]
  status       EmailCampaignStatus @default(DRAFT)
  scheduledAt  DateTime?
  sentAt       DateTime?
  cc           String[]
  bcc          String[]
  replyTo      String?
  openCount    Int                 @default(0)
  clickCount   Int                 @default(0)
  errorCount   Int                 @default(0)
  createdAt    DateTime            @default(now())

  club         Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  template     EmailTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  group        EmailGroup?         @relation(fields: [groupId], references: [id], onDelete: SetNull)
  logs         EmailLog[]

  @@index([clubId])
}

model EmailLog {
  id         String   @id @default(cuid())
  campaignId String
  recipient  String
  status     String
  openedAt   DateTime?
  clickedAt  DateTime?
  error      String?
  createdAt  DateTime @default(now())

  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

// ─── Subscriptions & Billing ─────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  clubId               String             @unique
  plan                 SubscriptionPlan   @default(TRIAL)
  status               SubscriptionStatus @default(TRIALING)
  billingInterval      BillingInterval    @default(MONTHLY)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  promoCodeId          String?
  referredByClubId     String?
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  club                 Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  promoCode            PromoCode?         @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
}

// ─── District Dashboard ──────────────────────────────────────────────────────

model DistrictAccess {
  id          String             @id @default(cuid())
  userId      String
  district    String
  role        DistrictAccessRole @default(VIEWER)
  canViewPV   Boolean            @default(false)
  grantedAt   DateTime           @default(now())
  expiresAt   DateTime?
  grantedById String?

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User?              @relation("DistrictAccessGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, district])
}

// ─── Notifications & Audit ───────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  clubId    String?
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  club      Club?            @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model AuditLog {
  id         String   @id @default(cuid())
  clubId     String?
  userId     String?
  action     String
  entity     String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  club       Club?    @relation(fields: [clubId], references: [id], onDelete: SetNull)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clubId, createdAt])
  @@index([userId])
}

// ─── SaaS Platform (Super Admin) ─────────────────────────────────────────────

model AppSettings {
  id                    String   @id @default("global")
  appName               String   @default("Rotary Minutes")
  tagline               String?
  supportEmail          String?
  contactToEmail        String?
  contactBccEmail       String?
  signupNotifyEmail     String?
  stripeEnabled         Boolean  @default(false)
  resendEnabled         Boolean  @default(false)
  trialDays             Int      @default(14)
  maintenanceMode       Boolean  @default(false)
  annualDiscountPercent Int      @default(20)
  currency              String   @default("EUR")
  config                Json?
  updatedAt             DateTime @updatedAt
}

model PlanConfig {
  plan                 SubscriptionPlan @id
  nameFr               String
  nameEn               String
  descriptionFr        String?
  descriptionEn        String?
  priceMonthly         Int
  featuresFr           String[]
  featuresEn           String[]
  stripePriceIdMonthly String?
  stripePriceIdAnnual  String?
  memberLimit          Int?
  isActive             Boolean          @default(true)
  isPopular            Boolean          @default(false)
  sortOrder            Int              @default(0)
  updatedAt            DateTime         @updatedAt
}

model ClubFeatures {
  clubId                  String   @id
  emailsEnabled           Boolean  @default(true)
  statisticsEnabled       Boolean  @default(true)
  districtDashboard       Boolean  @default(false)
  pdfExport               Boolean  @default(true)
  offlineMode             Boolean  @default(false)
  liveMeetings            Boolean  @default(true)
  emailsMenuVisible       Boolean  @default(false)
  statisticsMenuVisible   Boolean  @default(false)
  pdfMenuVisible          Boolean  @default(false)
  liveMeetingsMenuVisible Boolean  @default(false)
  districtMenuVisible     Boolean  @default(false)
  offlineMenuVisible      Boolean  @default(false)
  apiAccessEnabled        Boolean  @default(false)
  duesEnabled             Boolean  @default(true)
  duesMenuVisible         Boolean  @default(true)
  treasuryEnabled         Boolean  @default(true)
  treasuryMenuVisible     Boolean  @default(true)
  actionsEnabled          Boolean  @default(true)
  actionsMenuVisible      Boolean  @default(true)
  calendarEnabled         Boolean  @default(true)
  calendarMenuVisible     Boolean  @default(true)
  memberPortalEnabled     Boolean  @default(true)
  memberPortalMenuVisible Boolean  @default(true)
  attendanceReportsEnabled Boolean @default(true)
  attendanceReportsMenuVisible Boolean @default(false)
  eventsEnabled           Boolean  @default(true)
  eventsMenuVisible       Boolean  @default(true)
  documentsEnabled        Boolean  @default(true)
  documentsMenuVisible    Boolean  @default(true)
  governanceEnabled       Boolean  @default(true)
  governanceMenuVisible   Boolean  @default(false)
  smartNotificationsEnabled Boolean @default(true)
  integrationsEnabled     Boolean  @default(false)
  integrationsMenuVisible Boolean  @default(false)
  pwaEnhancedEnabled      Boolean  @default(true)
  eventsAdvancedEnabled   Boolean  @default(false)
  eventsAdvancedMenuVisible Boolean @default(false)
  fileManagerEnabled      Boolean  @default(false)
  fileManagerMenuVisible  Boolean  @default(false)
