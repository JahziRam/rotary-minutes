  name      String
  email     String
  clubName  String?
  topic     String
  message   String                  @db.Text
  locale    String                  @default("fr")
  status    ContactSubmissionStatus @default(NEW)
  ipAddress String?
  emailSent Boolean                 @default(false)
  createdAt DateTime                @default(now())
  readAt    DateTime?

  @@index([status, createdAt])
  @@index([email])
}

model CaseStudy {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleFr     String
  titleEn     String
  summaryFr   String
  summaryEn   String
  contentFr   String   @db.Text
  contentEn   String   @db.Text
  clubName    String
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model DemoSession {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── Phase 9: Feature flags & production ─────────────────────────────────────

model FeatureFlag {
  key             String   @id
  nameFr          String
  nameEn          String
  descriptionFr   String?
  descriptionEn   String?
  defaultEnabled  Boolean  @default(false)
  rolloutPercent  Int      @default(0)
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  overrides       ClubFeatureFlagOverride[]
}

model ClubFeatureFlagOverride {
  id        String   @id @default(cuid())
  clubId    String
  flagKey   String
  enabled   Boolean
  note      String?
  updatedAt DateTime @updatedAt

  club      Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  flag      FeatureFlag @relation(fields: [flagKey], references: [key], onDelete: Cascade)

  @@unique([clubId, flagKey])
  @@index([clubId])
}

// ─── Phase 10: Public API & webhooks ─────────────────────────────────────────

enum ApiKeyScope {
  READ_MINUTES
  READ_MEETINGS
  READ_MEMBERS
}

enum WebhookEvent {
  MINUTE_FINALIZED
  MEETING_CREATED
  MEMBER_CREATED
  DUES_PAID
  ACTION_COMPLETED
  EVENT_CREATED
  BUDGET_ENTRY_CREATED
}

model ClubApiKey {
  id          String        @id @default(cuid())
  clubId      String
  name        String
  keyPrefix   String
  keyHash     String
  scopes      ApiKeyScope[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean       @default(true)
  createdById String?
  createdAt   DateTime      @default(now())

  club        Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([keyPrefix])
}

model ClubWebhook {
  id         String         @id @default(cuid())
  clubId     String
  url        String
  secret     String
  events     WebhookEvent[]
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  club       Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([clubId])
}

model WebhookDelivery {
  id          String        @id @default(cuid())
  webhookId   String
  event       WebhookEvent
  payload     Json
  statusCode  Int?
  error       String?
  attempt     Int           @default(1)
  deliveredAt DateTime?
  createdAt   DateTime      @default(now())

  webhook     ClubWebhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
}

// ─── Club Management Modules ─────────────────────────────────────────────────

model BudgetCategory {
  id        String           @id @default(cuid())
  clubId    String
  name      String
  type      BudgetEntryType
  isActive  Boolean          @default(true)
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())

  club      Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  entries   BudgetEntry[]

  @@index([clubId, type])
}

model BudgetEntry {
  id            String           @id @default(cuid())
  clubId        String
  categoryId    String?
  subAccountId  String?
  type          BudgetEntryType
  amount        Decimal          @db.Decimal(10, 2)
  currency      String           @default("EUR")
  date          DateTime
  description   String
  eventId       String?
  duesPaymentId String?
  actionId      String?
  paymentMethod PaymentMethod?
  reference             String?
  collectionStatus      TreasuryCollectionStatus @default(COLLECTED)
  eventRegistrationId   String?                  @unique
  recordedById          String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  club                  Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  category              BudgetCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subAccount            TreasurySubAccount? @relation(fields: [subAccountId], references: [id], onDelete: SetNull)
  event                 ClubEvent?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  duesPayment           DuesPayment?     @relation(fields: [duesPaymentId], references: [id], onDelete: SetNull)
  action                ClubAction?      @relation(fields: [actionId], references: [id], onDelete: SetNull)
  eventRegistration     EventRegistration? @relation(fields: [eventRegistrationId], references: [id], onDelete: SetNull)
  recordedBy            User?            @relation(fields: [recordedById], references: [id], onDelete: SetNull)
  bankStatementMatches  BankStatementLine[]

  @@index([clubId, date])
  @@index([clubId, type])
  @@index([clubId, subAccountId])
}

model TreasurySubAccount {
  id            String   @id @default(cuid())
  clubId        String
  name          String
  code          String?
  description   String?  @db.Text
  budgetPlanned Decimal? @db.Decimal(12, 2)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  club    Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  entries BudgetEntry[]

  @@unique([clubId, name])
  @@index([clubId])
}

model BankStatementLine {
  id              String    @id @default(cuid())
  clubId          String
  date            DateTime
  description     String
  amount          Decimal   @db.Decimal(12, 2)
  reference       String?
  matchedEntryId  String?
  importedAt      DateTime  @default(now())

  club          Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  matchedEntry  BudgetEntry? @relation(fields: [matchedEntryId], references: [id], onDelete: SetNull)

  @@index([clubId, date])
  @@index([matchedEntryId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  clubId    String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club? @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clubId])
}

model ClubAnnouncement {
  id          String   @id @default(cuid())
  clubId      String
  authorId    String
  title       String
  message     String   @db.Text
  targetRoles String[]
  createdAt   DateTime @default(now())

  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([clubId, createdAt])
}

model ClubEmailSettings {
  clubId             String    @id
  useCustomSmtp      Boolean   @default(false)
  smtpHost           String?
  smtpPort           Int?      @default(587)
  smtpSecure         Boolean   @default(false)
  smtpUser           String?
  smtpPassword       String?
  smtpFrom           String?
  smtpFromName       String?
  lastSmtpError      String?
  lastSmtpFallbackAt DateTime?
  updatedAt          DateTime  @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ClubDuesPaymentSettings {
  clubId              String   @id
  stripeEnabled       Boolean  @default(false)
  stripeSecretKey     String?
  stripeWebhookSecret String?
  paymentInstructions String?  @db.Text
  updatedAt           DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ClubAction {
  id                 String             @id @default(cuid())
  clubId             String
  title              String
  description        String?            @db.Text
  responsibleMemberId String?
  responsibleName    String?
  dueDate            DateTime?
  status             ClubActionStatus   @default(OPEN)
  priority           ClubActionPriority @default(NORMAL)
  minuteId           String?
  agendaItemId       String?
  lastRemindedAt     DateTime?
  completedAt        DateTime?
  createdById        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  club               Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  responsibleMember  Member?            @relation("MemberAssignedActions", fields: [responsibleMemberId], references: [id], onDelete: SetNull)
  minute             Minute?            @relation(fields: [minuteId], references: [id], onDelete: SetNull)
  agendaItem         AgendaItem?        @relation(fields: [agendaItemId], references: [id], onDelete: SetNull)
  createdBy          User?              @relation("ActionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  budgetEntries      BudgetEntry[]

  @@index([clubId, status])
  @@index([clubId, dueDate])
  @@index([responsibleMemberId])
}

model ClubCalendarNote {
  id          String              @id @default(cuid())
  clubId      String
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  source      CalendarEventSource @default(CUSTOM)
  color       String?
  createdAt   DateTime            @default(now())

  club        Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, startAt])
}

model ClubEvent {
  id              String           @id @default(cuid())
  clubId          String
  title           String
  description     String?          @db.Text
  location        String?
  startAt         DateTime
  endAt           DateTime?
  status          ClubEventStatus  @default(DRAFT)
  maxAttendees    Int?
  price           Decimal?         @db.Decimal(10, 2)
  currency        String           @default("EUR")
  requiresPayment Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  club            Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  registrations   EventRegistration[]
  budgetEntries   BudgetEntry[]
  priceTiers      EventPriceTier[]
  ticketSlots     EventTicketSlot[]

  @@index([clubId, startAt])
  @@index([clubId, status])
}

model EventPriceTier {
  id        String   @id @default(cuid())
  eventId   String
  label     String
  price     Decimal  @db.Decimal(10, 2)
  sortOrder Int      @default(0)
  maxQty    Int?
  createdAt DateTime @default(now())

  event           ClubEvent           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations   EventRegistration[]

  @@index([eventId])
}

model EventTicketSlot {
  id             String   @id @default(cuid())
  eventId        String
  ticketNumber   String
  label          String?
  isReserved     Boolean  @default(false)
  registrationId String?  @unique
  createdAt      DateTime @default(now())

  event          ClubEvent            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration   EventRegistration?   @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  @@unique([eventId, ticketNumber])
  @@index([eventId])
}

model EventRegistration {
  id            String                  @id @default(cuid())
  eventId       String
  memberId      String?
  guestName     String?
  email         String?
  phone         String?
  orderGroupId  String?
  quantity      Int                     @default(1)
  priceTierId   String?
  status        EventRegistrationStatus @default(PENDING)
  paidAt        DateTime?
  paymentMethod PaymentMethod?
  amount        Decimal?                @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime                @default(now())

  event         ClubEvent               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member        Member?                 @relation(fields: [memberId], references: [id], onDelete: SetNull)
  priceTier     EventPriceTier?         @relation(fields: [priceTierId], references: [id], onDelete: SetNull)
  ticketSlot    EventTicketSlot?
  treasuryEntry BudgetEntry?

  @@index([eventId])
  @@index([memberId])
  @@index([orderGroupId])
}

model DocumentFolder {
  id        String   @id @default(cuid())
  clubId    String
  parentId  String?
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club      Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  parent    DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  DocumentFolder[] @relation("FolderTree")
  documents ClubDocument[]

  @@index([clubId, parentId])
}

model ClubDocument {
  id              String           @id @default(cuid())
  clubId          String
  folderId        String?
  title           String
  category        DocumentCategory @default(OTHER)
  description     String?
  fileUrl         String?
  fileName        String?
  mimeType        String?
  minuteId        String?
  isArchived      Boolean          @default(false)
  isShareEnabled  Boolean          @default(false)
  shareToken      String?          @unique
  shareExpiresAt  DateTime?
  tags            String[]
  uploadedById    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  club            Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  folder          DocumentFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  minute          Minute?          @relation(fields: [minuteId], references: [id], onDelete: SetNull)
  uploadedBy      User?            @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([clubId, category])
  @@index([clubId, folderId])
  @@index([clubId, createdAt])
}

model ClubBackup {
  id          String          @id @default(cuid())
  clubId      String
  scope       BackupScope
  status      BackupJobStatus @default(PENDING)
  fileName    String?
  payload     String?         @db.Text
  sqlPayload  String?         @db.Text
  sizeBytes   Int?
  createdById String?
  createdAt   DateTime        @default(now())
  completedAt DateTime?

  club        Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdBy   User?           @relation("ClubBackupCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([clubId, createdAt])
}

model PlatformBackup {
  id          String          @id @default(cuid())
  scope       BackupScope
  status      BackupJobStatus @default(PENDING)
  fileName    String?
  payload     String?         @db.Text
  sqlPayload  String?         @db.Text
  sizeBytes   Int?
  createdById String?
  createdAt   DateTime        @default(now())
  completedAt DateTime?

  createdBy   User?           @relation("PlatformBackupCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model GovernanceRecord {
  id          String               @id @default(cuid())
  clubId      String
  type        GovernanceRecordType
  title       String
  description String?              @db.Text
  holderName  String?
  memberId    String?
  minuteId    String?
  mandateId   String?
  effectiveAt DateTime
  createdById String?
  createdAt   DateTime             @default(now())

  club        Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  minute      Minute?              @relation(fields: [minuteId], references: [id], onDelete: SetNull)
  mandate     OfficerMandate?      @relation(fields: [mandateId], references: [id], onDelete: SetNull)
  createdBy   User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([clubId, effectiveAt])
  @@index([clubId, type])
}

model NotificationPreference {
  id                String                @id @default(cuid())
  userId            String
  clubId            String?
  emailEnabled      Boolean               @default(true)
  inAppEnabled      Boolean               @default(true)
  meetingReminders  NotificationFrequency @default(IMMEDIATE)
  duesReminders     NotificationFrequency @default(IMMEDIATE)
  actionReminders   NotificationFrequency @default(IMMEDIATE)
  birthdayReminders NotificationFrequency @default(WEEKLY)
  eventReminders    NotificationFrequency @default(IMMEDIATE)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([userId])
}